<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
        
    <UserSecretsId>Tests.Odin.Email</UserSecretsId>
    <GenerateProgramFile>false</GenerateProgramFile>
    <ImplicitUsings>true</ImplicitUsings>
    <NoWarn>1591;</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="xunit.v3"/>
    <PackageReference Include="Moq"  />
    <PackageReference Include="xunit.runner.visualstudio">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.NET.Test.Sdk"/> 
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>
  <!-- IMPORTANT: match Mvc.Testing major version to the TFM -->
  <ItemGroup >
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing"/>
  </ItemGroup>
  
  <ItemGroup>
    <ProjectReference Include="..\Core\Odin.Email.csproj" />
    <ProjectReference Include="..\Mailgun\Odin.Email.Mailgun.csproj" />
    <ProjectReference Include="..\Office365\Odin.Email.Office365.csproj" />
   </ItemGroup>
  <ItemGroup>
    <None Update="appSettings.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
